target/
**/*.rs.bk
.DS_Store
# Cargo.lock IS committed: this is a deployable workspace, and the lock pins the
# exact fork versions the stack needs (a fresh resolve can drift to registry
# versions that bypass the required forks).
*.log
# Secrets / credentials — NEVER commit. Copy the *.example templates and fill
# your own values locally.
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.p12
credentials.json
# the portal's wasm light-client bundle (~15MB) is built from the public dregg
# substrate (breadstuffs/wasm/pkg) by deploy.sh at stage time — kept out of git
# (the .gitkeep documents the dir).
deploy/staging/portal/pkg/dregg_wasm*
deploy/staging/portal/pkg/snippets/
# local staging build output (binaries + filled .env) — never commit.
deploy/staging/.stage/
