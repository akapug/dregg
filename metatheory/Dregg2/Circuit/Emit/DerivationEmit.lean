/-
# Dregg2.Circuit.Emit.DerivationEmit — the Datalog DERIVATION AIR, emitted from Lean.

## What this file IS

A `EffectVmDescriptor2` that DECLARES, in the IR-v2 grammar, the FULL derivation-step statement the
hand-written DSL AIR (`circuit/src/dsl/derivation.rs::derivation_circuit_descriptor`) enforces: a
Datalog rule FIRES — its head fact is the genuine `hash_fact` of `(head_pred, head_terms)`, the head
terms are the substitution-application of the rule over the bound variables, the body facts are
membership-authenticated against the committed `state_root`, and the `eq`/`memberof`/`gte`/`lt`
side-conditions hold (the two 30-bit comparators by bit-decomposition).

This is the emit-from-Lean twin of that hand AIR. Its constraint list is a CONSTRAINT-FOR-CONSTRAINT
transcription of the 28 constraint families C1..C28 + the two boundary PI pins, over the SAME
371-column derivation layout (`derivation_air::col`), extended by the 8 C2 inverse columns
(`BODY_HASH_INV_START`, giving `EXTENDED_TRACE_WIDTH = 379`) and the 7 exposed chip lanes of the ONE
C4 `hash_fact` site (`379..386`, `traceWidth = 386`).

## The constraint mapping (each hand-AIR `ConstraintExpr` → its `VmConstraint2`)

* C1/C7/C8/C11/C13/C15/C20/C25/C26 `Binary{col}`      → `Base(Gate(col·(col−1)))`.
* C2 `ConditionalNonzero{sel,val,inv}`                → `Base(Gate(sel·(val·inv − 1)))` (deg 3; the
  8 inverse columns 371..379 ride as aux, filled by the real producer).
* C3 `AtLeastOne{flags}`                              → `Base(Gate(∏(1 − flag_i)))` (deg 8, the whole
  batch's degree ceiling — inside `ir2_config`'s `log_blowup = 6`).
* C4 `Hash{DERIVED_HASH, [HEAD_PRED, HEAD_TERM0..3]}` → an arity-7 `Poseidon2Chip` (`TID_P2`) lookup
  seeded `[7, pred, t0..t3, 0xFACF, 1, 0…]` binding out0 to `DERIVED_HASH`. THE ONE genuine
  non-arithmetic tooth: `chip_absorb_all_lanes(7, [pred,t0..t3,0xFACF,1])[0] == hash_fact(pred,
  terms)` (the DECO `fact_site` KAT), so a forged `derived_hash` names an UNSERVED chip row ⇒ UNSAT.
* C5 `Gated{flag, PiBinding{root_i, pi[0]}}`          → `Base(Gate(flag_i·(root_i − root_0)))`,
  reformulated relative to `root_0 = BODY_ROOT_START` (LeanExpr has no PI leaf); `root_0` is itself
  PI-pinned to `pi[0]` by the boundary pin, so an active body root ≠ the committed `state_root` is
  UNSAT (the state-binding tooth), exactly as the gated PI-binding did.
* C6 + the 2 boundaries `PiBinding{col, pi}`          → `Base(PiBinding{First, col, pi})`
  (`DERIVED_HASH == pi[1]` the published conclusion; `BODY_ROOT_START == pi[0]` the committed root).
* C9/C10/C27 `Squared{Polynomial P}`                  → `Base(Gate(P·P))` (the sel/is_var
  substitution-selector identities; deg ≤ 4).
* C12/C14 `Gated{active, Equality{a,b}}`              → `Base(Gate(active·(a − b)))`.
* C16..C24 `Gated{active, Polynomial/Binary}`         → `Base(Gate(active·body))`: the diff
  definitions, the `Σ bit_i·2^i = diff` recompositions, the 30 bit-booleans, and the
  high-bit-zero range tooth (`active·bit_29`), for BOTH the GTE and LT comparators. The
  bit-decomposition range proof is arithmetic here EXACTLY as the hand AIR writes it (not a
  `TableSem::Range` lookup) — an out-of-range diff (high bit set) is UNSAT.
* C28 `Gated{active, Polynomial}`                     → `Base(Gate(active·body))`: the 20 check-term
  bindings (`trace_term == is_var ? sub[sel] : raw`).

## Axiom hygiene

Definitional descriptor + a byte-pinned `#guard` on `emitVmJson2` + one genuinely-proven,
non-vacuous semantic lemma (`gteHighBit_zero_iff`, the range high-bit tooth: TRUE iff in-range or
inactive, FALSE for an active out-of-range diff). NEW file; imports read-only.
-/
import Dregg2.Circuit.DescriptorIR2

namespace Dregg2.Circuit.Emit.DerivationEmit

open Dregg2.Circuit (Assignment)
open Dregg2.Exec.CircuitEmit (EmittedExpr)
open Dregg2.Circuit.Emit.EffectVmEmit (VmConstraint VmRow)
open Dregg2.Circuit.DescriptorIR2
  (EffectVmDescriptor2 VmConstraint2 Lookup TableId CHIP_RATE CHIP_OUT_LANES emitVmJson2)

set_option autoImplicit false

/-! ## §1 — The column layout (mirrors `circuit/src/derivation_air.rs::col`, verbatim). -/

def MAX_BODY_ATOMS : Nat := 8
def MAX_SUB_VARS : Nat := 8
def MAX_HEAD_TERMS : Nat := 4
def MAX_EQUAL_CHECKS : Nat := 4
def MAX_MEMBEROF_CHECKS : Nat := 4
def GTE_DIFF_BITS : Nat := 30

def RULE_ID : Nat := 0
def BODY_HASH_START : Nat := 1
def BODY_MEMBERSHIP_START : Nat := BODY_HASH_START + MAX_BODY_ATOMS      -- 9
def HEAD_PRED : Nat := BODY_MEMBERSHIP_START + MAX_BODY_ATOMS            -- 17
def HEAD_TERM_START : Nat := HEAD_PRED + 1                              -- 18
def DERIVED_HASH : Nat := HEAD_TERM_START + MAX_HEAD_TERMS              -- 22
def SUB_VALUE_START : Nat := DERIVED_HASH + 1                           -- 23
def BODY_ROOT_START : Nat := SUB_VALUE_START + MAX_SUB_VARS             -- 31
def HEAD_IS_VAR_START : Nat := BODY_ROOT_START + MAX_BODY_ATOMS         -- 39
def HEAD_RAW_VALUE_START : Nat := HEAD_IS_VAR_START + MAX_HEAD_TERMS    -- 43
def HEAD_SEL_VAR_START : Nat := HEAD_RAW_VALUE_START + MAX_HEAD_TERMS   -- 47
def headSelVar (termIdx varIdx : Nat) : Nat := HEAD_SEL_VAR_START + termIdx * MAX_SUB_VARS + varIdx

def EQ_CHECK_START : Nat := HEAD_SEL_VAR_START + MAX_HEAD_TERMS * MAX_SUB_VARS  -- 79
def eqCheckActive (i : Nat) : Nat := EQ_CHECK_START + i * 3
def eqCheckTermA (i : Nat) : Nat := EQ_CHECK_START + i * 3 + 1
def eqCheckTermB (i : Nat) : Nat := EQ_CHECK_START + i * 3 + 2

def MEMBEROF_CHECK_START : Nat := EQ_CHECK_START + MAX_EQUAL_CHECKS * 3         -- 91
def memberofCheckActive (i : Nat) : Nat := MEMBEROF_CHECK_START + i * 3
def memberofCheckTermA (i : Nat) : Nat := MEMBEROF_CHECK_START + i * 3 + 1
def memberofCheckTermB (i : Nat) : Nat := MEMBEROF_CHECK_START + i * 3 + 2

def GTE_CHECK_START : Nat := MEMBEROF_CHECK_START + MAX_MEMBEROF_CHECKS * 3     -- 103
def GTE_CHECK_ACTIVE : Nat := GTE_CHECK_START
def GTE_CHECK_TERM_A : Nat := GTE_CHECK_START + 1
def GTE_CHECK_TERM_B : Nat := GTE_CHECK_START + 2
def GTE_CHECK_DIFF : Nat := GTE_CHECK_START + 3
def GTE_CHECK_DIFF_BITS_START : Nat := GTE_CHECK_START + 4                      -- 107
def gteDiffBit (i : Nat) : Nat := GTE_CHECK_DIFF_BITS_START + i

def LT_CHECK_START : Nat := GTE_CHECK_DIFF_BITS_START + GTE_DIFF_BITS           -- 137
def LT_CHECK_ACTIVE : Nat := LT_CHECK_START
def LT_CHECK_TERM_A : Nat := LT_CHECK_START + 1
def LT_CHECK_TERM_B : Nat := LT_CHECK_START + 2
def LT_CHECK_DIFF : Nat := LT_CHECK_START + 3
def LT_CHECK_DIFF_BITS_START : Nat := LT_CHECK_START + 4                        -- 141
def ltDiffBit (i : Nat) : Nat := LT_CHECK_DIFF_BITS_START + i

def CHECK_TERM_COLS : Nat := 1 + 1 + MAX_SUB_VARS                              -- 10
def CHECK_TERM_BINDING_START : Nat := LT_CHECK_DIFF_BITS_START + GTE_DIFF_BITS  -- 171
def NUM_CHECK_TERMS : Nat := MAX_EQUAL_CHECKS * 2 + MAX_MEMBEROF_CHECKS * 2 + 2 + 2  -- 20
def checkTermBase (slot : Nat) : Nat := CHECK_TERM_BINDING_START + slot * CHECK_TERM_COLS
def checkTermIsVar (slot : Nat) : Nat := checkTermBase slot
def checkTermRawValue (slot : Nat) : Nat := checkTermBase slot + 1
def checkTermSel (slot varIdx : Nat) : Nat := checkTermBase slot + 2 + varIdx

def eqTermASlot (i : Nat) : Nat := i * 2
def eqTermBSlot (i : Nat) : Nat := i * 2 + 1
def memberofTermASlot (i : Nat) : Nat := MAX_EQUAL_CHECKS * 2 + i * 2
def memberofTermBSlot (i : Nat) : Nat := MAX_EQUAL_CHECKS * 2 + i * 2 + 1
def GTE_TERM_A_SLOT : Nat := MAX_EQUAL_CHECKS * 2 + MAX_MEMBEROF_CHECKS * 2     -- 16
def GTE_TERM_B_SLOT : Nat := GTE_TERM_A_SLOT + 1
def LT_TERM_A_SLOT : Nat := GTE_TERM_B_SLOT + 1
def LT_TERM_B_SLOT : Nat := LT_TERM_A_SLOT + 1

/-- `DERIVATION_AIR_WIDTH` — the 371-column derivation layout total. -/
def DERIVATION_AIR_WIDTH : Nat := CHECK_TERM_BINDING_START + NUM_CHECK_TERMS * CHECK_TERM_COLS  -- 371
/-- The 8 C2 inverse aux columns start here. -/
def BODY_HASH_INV_START : Nat := DERIVATION_AIR_WIDTH                          -- 371
/-- Extended width: base 371 + 8 inverse columns. -/
def EXTENDED_TRACE_WIDTH : Nat := DERIVATION_AIR_WIDTH + MAX_BODY_ATOMS        -- 379
/-- Base of the 7 exposed chip lanes of the single C4 hash site. -/
def C4_LANE_BASE : Nat := EXTENDED_TRACE_WIDTH                                 -- 379
/-- Full main-trace width: 379 + (CHIP_OUT_LANES − 1) = 386. -/
def DERIV_TRACE_WIDTH : Nat := EXTENDED_TRACE_WIDTH + (CHIP_OUT_LANES - 1)     -- 386

/-! ## §2 — Expression + gate helpers (mirrored EXACTLY in the Rust gate's builder). -/

/-- `x − y` (no subtraction node: `x + (−1)·y`). -/
def subE (x y : EmittedExpr) : EmittedExpr := .add x (.mul (.const (-1)) y)

/-- The binary-body `c·(c − 1)`. -/
def binBody (c : Nat) : EmittedExpr := .mul (.var c) (.add (.var c) (.const (-1)))

/-- The product `∏ var cols` (empty ⇒ `const 1`), left-associated. -/
def prodCols : List Nat → EmittedExpr
  | []      => .const 1
  | c :: cs => cs.foldl (fun acc d => .mul acc (.var d)) (.var c)

/-- One polynomial term `coeff · ∏ cols`, matching the Rust DSL `term` lowering. -/
def termE (coeff : Int) (cols : List Nat) : EmittedExpr :=
  if cols.isEmpty then .const coeff
  else if coeff = 1 then prodCols cols
  else if coeff = -1 then .mul (.const (-1)) (prodCols cols)
  else .mul (.const coeff) (prodCols cols)

/-- A polynomial `Σ terms` (empty ⇒ `const 0`), left-associated. -/
def polyE : List EmittedExpr → EmittedExpr
  | []      => .const 0
  | t :: ts => ts.foldl (fun acc e => .add acc e) t

/-- A vanishing base gate. -/
def gate (body : EmittedExpr) : VmConstraint2 := .base (.gate body)

/-- A binary base gate. -/
def binGate (c : Nat) : VmConstraint2 := gate (binBody c)

/-- A gated base gate `active · body`. -/
def gatedGate (active : Nat) (body : EmittedExpr) : VmConstraint2 :=
  gate (.mul (.var active) body)

/-- A First-row PI pin. -/
def pin (col piIndex : Nat) : VmConstraint2 := .base (.piBinding VmRow.first col piIndex)

/-! ## §3 — The C4 `hash_fact` chip fact-site (the DECO `fact_site` shape, arity tag 7).

The tuple is `[7, pred, t0..t3, 0xFACF, 1, 0×9, DERIVED_HASH, lane1..7]` — 25 = `CHIP_RATE + 1 +
CHIP_OUT_LANES`. `chip_absorb_all_lanes(7, [pred,t0..t3,0xFACF,1])[0] == hash_fact(pred, terms)`. -/

/-- The 16 rate slots of the C4 fact site: the 5 head inputs, the `0xFACF` leaf marker, the leaf
flag `1`, then 9 zero-pads. -/
def c4RateSlots : List EmittedExpr :=
  [ .var HEAD_PRED, .var HEAD_TERM_START, .var (HEAD_TERM_START + 1)
  , .var (HEAD_TERM_START + 2), .var (HEAD_TERM_START + 3)
  , .const 64207, .const 1
  , .const 0, .const 0, .const 0, .const 0, .const 0, .const 0, .const 0, .const 0, .const 0 ]

def c4LaneCols : List Nat := (List.range (CHIP_OUT_LANES - 1)).map (fun j => C4_LANE_BASE + j)

def c4FactSiteTuple : List EmittedExpr :=
  .const 7 :: c4RateSlots ++ (.var DERIVED_HASH :: c4LaneCols.map (.var ·))

def c4Lookup : VmConstraint2 := .lookup ⟨TableId.poseidon2, c4FactSiteTuple⟩

/-! ## §4 — The constraint families C1..C28 (in `derivation_circuit_descriptor` order). -/

def bodyFlag (i : Nat) : Nat := BODY_MEMBERSHIP_START + i
def bodyHash (i : Nat) : Nat := BODY_HASH_START + i
def bodyInv (i : Nat) : Nat := BODY_HASH_INV_START + i
def bodyRoot (i : Nat) : Nat := BODY_ROOT_START + i
def headIsVar (i : Nat) : Nat := HEAD_IS_VAR_START + i
def headRaw (i : Nat) : Nat := HEAD_RAW_VALUE_START + i
def headTerm (i : Nat) : Nat := HEAD_TERM_START + i
def subValue (v : Nat) : Nat := SUB_VALUE_START + v

/-- C1: each of the 8 body-membership flags is binary. -/
def c1 : List VmConstraint2 := (List.range MAX_BODY_ATOMS).map (fun i => binGate (bodyFlag i))

/-- C2: `flag_i · (hash_i · inv_i − 1) = 0` — a used body slot's fact hash is nonzero. -/
def c2 : List VmConstraint2 := (List.range MAX_BODY_ATOMS).map (fun i =>
  gate (.mul (.var (bodyFlag i)) (subE (.mul (.var (bodyHash i)) (.var (bodyInv i))) (.const 1))))

/-- C3: at least one body flag is 1 — `∏(1 − flag_i) = 0` (degree 8). -/
def c3 : List VmConstraint2 :=
  [ gate ((List.range MAX_BODY_ATOMS).foldl
      (fun acc i => .mul acc (subE (.const 1) (.var (bodyFlag i)))) (.const 1)) ]

/-- C4: the derived-hash chip site. -/
def c4 : List VmConstraint2 := [ c4Lookup ]

/-- C5: each active body root equals `root_0` (itself PI-pinned to `pi[0]`). -/
def c5 : List VmConstraint2 := (List.range MAX_BODY_ATOMS).map (fun i =>
  gate (.mul (.var (bodyFlag i)) (subE (.var (bodyRoot i)) (.var BODY_ROOT_START))))

/-- C6: `DERIVED_HASH == pi[1]` (the published conclusion). -/
def c6 : List VmConstraint2 := [ pin DERIVED_HASH 1 ]

/-- C7: each head `is_var` flag is binary. -/
def c7 : List VmConstraint2 := (List.range MAX_HEAD_TERMS).map (fun i => binGate (headIsVar i))

/-- C8: each of the 4×8 head substitution selectors is binary. -/
def c8 : List VmConstraint2 :=
  (List.range MAX_HEAD_TERMS).flatMap (fun t =>
    (List.range MAX_SUB_VARS).map (fun v => binGate (headSelVar t v)))

/-- C9: `(Σ_v sel(t,v) − is_var_t)^2 = 0`. -/
def c9 : List VmConstraint2 := (List.range MAX_HEAD_TERMS).map (fun t =>
  let p := polyE ((List.range MAX_SUB_VARS).map (fun v => termE 1 [headSelVar t v])
                    ++ [termE (-1) [headIsVar t]])
  gate (.mul p p))

/-- C10: `(derived_t − raw_t + is_var_t·raw_t − Σ_v sel(t,v)·sub_v)^2 = 0`. -/
def c10 : List VmConstraint2 := (List.range MAX_HEAD_TERMS).map (fun t =>
  let p := polyE ([ termE 1 [headTerm t], termE (-1) [headRaw t], termE 1 [headIsVar t, headRaw t] ]
                    ++ (List.range MAX_SUB_VARS).map (fun v => termE (-1) [headSelVar t v, subValue v]))
  gate (.mul p p))

/-- C11: each equal-check active flag is binary. -/
def c11 : List VmConstraint2 := (List.range MAX_EQUAL_CHECKS).map (fun i => binGate (eqCheckActive i))

/-- C12: `active_i · (eq_term_a − eq_term_b) = 0`. -/
def c12 : List VmConstraint2 := (List.range MAX_EQUAL_CHECKS).map (fun i =>
  gatedGate (eqCheckActive i) (subE (.var (eqCheckTermA i)) (.var (eqCheckTermB i))))

/-- C13: each memberof-check active flag is binary. -/
def c13 : List VmConstraint2 := (List.range MAX_MEMBEROF_CHECKS).map (fun i => binGate (memberofCheckActive i))

/-- C14: `active_i · (mo_term_a − mo_term_b) = 0`. -/
def c14 : List VmConstraint2 := (List.range MAX_MEMBEROF_CHECKS).map (fun i =>
  gatedGate (memberofCheckActive i) (subE (.var (memberofCheckTermA i)) (.var (memberofCheckTermB i))))

/-- C15: the GTE active flag is binary. -/
def c15 : List VmConstraint2 := [ binGate GTE_CHECK_ACTIVE ]

/-- C16: `active · (diff − term_a + term_b) = 0`. -/
def c16 : List VmConstraint2 := [ gatedGate GTE_CHECK_ACTIVE
  (polyE [termE 1 [GTE_CHECK_DIFF], termE (-1) [GTE_CHECK_TERM_A], termE 1 [GTE_CHECK_TERM_B]]) ]

/-- C17: `active · (Σ bit_i·2^i − diff) = 0`. -/
def c17 : List VmConstraint2 := [ gatedGate GTE_CHECK_ACTIVE
  (polyE ((List.range GTE_DIFF_BITS).map (fun i => termE ((2 : Int) ^ i) [gteDiffBit i])
            ++ [termE (-1) [GTE_CHECK_DIFF]])) ]

/-- C18: each GTE diff bit is binary (gated). -/
def c18 : List VmConstraint2 := (List.range GTE_DIFF_BITS).map (fun i =>
  gatedGate GTE_CHECK_ACTIVE (binBody (gteDiffBit i)))

/-- C19: the GTE high bit is zero (the out-of-range range tooth). -/
def c19 : List VmConstraint2 := [ gatedGate GTE_CHECK_ACTIVE
  (polyE [termE 1 [gteDiffBit (GTE_DIFF_BITS - 1)]]) ]

/-- C20: the LT active flag is binary. -/
def c20 : List VmConstraint2 := [ binGate LT_CHECK_ACTIVE ]

/-- C21: `active · (diff − term_b + term_a + 1) = 0`. -/
def c21 : List VmConstraint2 := [ gatedGate LT_CHECK_ACTIVE
  (polyE [termE 1 [LT_CHECK_DIFF], termE (-1) [LT_CHECK_TERM_B], termE 1 [LT_CHECK_TERM_A], termE 1 []]) ]

/-- C22: `active · (Σ lt_bit_i·2^i − lt_diff) = 0`. -/
def c22 : List VmConstraint2 := [ gatedGate LT_CHECK_ACTIVE
  (polyE ((List.range GTE_DIFF_BITS).map (fun i => termE ((2 : Int) ^ i) [ltDiffBit i])
            ++ [termE (-1) [LT_CHECK_DIFF]])) ]

/-- C23: each LT diff bit is binary (gated). -/
def c23 : List VmConstraint2 := (List.range GTE_DIFF_BITS).map (fun i =>
  gatedGate LT_CHECK_ACTIVE (binBody (ltDiffBit i)))

/-- C24: the LT high bit is zero. -/
def c24 : List VmConstraint2 := [ gatedGate LT_CHECK_ACTIVE
  (polyE [termE 1 [ltDiffBit (GTE_DIFF_BITS - 1)]]) ]

/-- C25: each of the 20 check-term `is_var` flags is binary. -/
def c25 : List VmConstraint2 := (List.range NUM_CHECK_TERMS).map (fun slot => binGate (checkTermIsVar slot))

/-- C26: each of the 20×8 check-term selectors is binary. -/
def c26 : List VmConstraint2 :=
  (List.range NUM_CHECK_TERMS).flatMap (fun slot =>
    (List.range MAX_SUB_VARS).map (fun v => binGate (checkTermSel slot v)))

/-- C27: `(Σ_v check_term_sel(slot,v) − check_term_is_var(slot))^2 = 0`. -/
def c27 : List VmConstraint2 := (List.range NUM_CHECK_TERMS).map (fun slot =>
  let p := polyE ((List.range MAX_SUB_VARS).map (fun v => termE 1 [checkTermSel slot v])
                    ++ [termE (-1) [checkTermIsVar slot]])
  gate (.mul p p))

/-- One C28 binding: `active · (trace_term − raw + is_var·raw − Σ_v sel(slot,v)·sub_v) = 0`. -/
def c28Binding (active traceCol slot : Nat) : VmConstraint2 :=
  gatedGate active
    (polyE ([ termE 1 [traceCol], termE (-1) [checkTermRawValue slot]
            , termE 1 [checkTermIsVar slot, checkTermRawValue slot] ]
      ++ (List.range MAX_SUB_VARS).map (fun v => termE (-1) [checkTermSel slot v, subValue v])))

/-- C28: the 20 check-term bindings (eq a/b ×4, memberof a/b ×4, gte a/b, lt a/b). -/
def c28 : List VmConstraint2 :=
  (List.range MAX_EQUAL_CHECKS).flatMap (fun i =>
    [ c28Binding (eqCheckActive i) (eqCheckTermA i) (eqTermASlot i)
    , c28Binding (eqCheckActive i) (eqCheckTermB i) (eqTermBSlot i) ])
  ++ (List.range MAX_MEMBEROF_CHECKS).flatMap (fun i =>
    [ c28Binding (memberofCheckActive i) (memberofCheckTermA i) (memberofTermASlot i)
    , c28Binding (memberofCheckActive i) (memberofCheckTermB i) (memberofTermBSlot i) ])
  ++ [ c28Binding GTE_CHECK_ACTIVE GTE_CHECK_TERM_A GTE_TERM_A_SLOT
     , c28Binding GTE_CHECK_ACTIVE GTE_CHECK_TERM_B GTE_TERM_B_SLOT
     , c28Binding LT_CHECK_ACTIVE LT_CHECK_TERM_A LT_TERM_A_SLOT
     , c28Binding LT_CHECK_ACTIVE LT_CHECK_TERM_B LT_TERM_B_SLOT ]

/-- The two boundary PI pins: `DERIVED_HASH == pi[1]` and `BODY_ROOT_START == pi[0]`. -/
def boundaries : List VmConstraint2 := [ pin DERIVED_HASH 1, pin BODY_ROOT_START 0 ]

/-- The full derivation constraint list, in `derivation_circuit_descriptor` order. -/
def derivationConstraints : List VmConstraint2 :=
  c1 ++ c2 ++ c3 ++ c4 ++ c5 ++ c6 ++ c7 ++ c8 ++ c9 ++ c10 ++ c11 ++ c12 ++ c13 ++ c14
    ++ c15 ++ c16 ++ c17 ++ c18 ++ c19 ++ c20 ++ c21 ++ c22 ++ c23 ++ c24
    ++ c25 ++ c26 ++ c27 ++ c28 ++ boundaries

/-- **`derivationDesc`** — the full Datalog derivation-step descriptor. `tables := []` (the
`TID_P2` chip is Presence-detected from the C4 lookup). -/
def derivationDesc : EffectVmDescriptor2 :=
  { name        := "dregg-derivation-v1"
  , traceWidth  := DERIV_TRACE_WIDTH
  , piCount     := 5
  , tables      := []
  , constraints := derivationConstraints
  , hashSites   := []
  , ranges      := [] }

/-! ## §5 — Shape pins. -/

#guard DERIVATION_AIR_WIDTH == 371
#guard EXTENDED_TRACE_WIDTH == 379
#guard DERIV_TRACE_WIDTH == 386
#guard NUM_CHECK_TERMS == 20
#guard GTE_TERM_A_SLOT == 16
#guard c4FactSiteTuple.length == CHIP_RATE + 1 + CHIP_OUT_LANES
#guard derivationConstraints.length == 377
#guard derivationDesc.piCount == 5

