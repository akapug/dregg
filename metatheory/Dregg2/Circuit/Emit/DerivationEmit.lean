/-! ## §6 — A genuinely-proven, non-vacuous semantic lemma: the range high-bit tooth.

The C19 gate body `active · bit_29` vanishes EXACTLY when the comparator is inactive OR the diff's
high bit is zero (in range) — and does NOT vanish for an ACTIVE, out-of-range (high-bit-set) diff.
This is the Lean face of the range tooth the emitted C19/C24 gates enforce row-for-row. -/

def gteHighBitBody : EmittedExpr := .mul (.var GTE_CHECK_ACTIVE) (.var (gteDiffBit (GTE_DIFF_BITS - 1)))

theorem gteHighBit_zero_iff (a : Assignment) :
    gteHighBitBody.eval a = 0 ↔ a GTE_CHECK_ACTIVE = 0 ∨ a (gteDiffBit (GTE_DIFF_BITS - 1)) = 0 := by
  simp only [gteHighBitBody, EmittedExpr.eval]
  exact mul_eq_zero

-- Non-vacuity: an ACTIVE out-of-range diff (high bit 1) is REJECTED; an in-range one is ACCEPTED.
#guard decide (¬ (gteHighBitBody.eval
  (fun i => if i = GTE_CHECK_ACTIVE ∨ i = gteDiffBit (GTE_DIFF_BITS - 1) then 1 else 0) = 0))
#guard decide (gteHighBitBody.eval (fun i => if i = GTE_CHECK_ACTIVE then 1 else 0) = 0)

#assert_axioms gteHighBit_zero_iff

end Dregg2.Circuit.Emit.DerivationEmit
