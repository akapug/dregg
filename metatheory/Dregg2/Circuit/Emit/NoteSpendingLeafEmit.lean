/-- The fixed descriptor genuinely BINDS `COMMITMENT` to `COMMITMENT_FULL` on the last row: on a spend
row (`is_merkle = 0`) the appended boundary forces col5 = col54. The zero-vanishing IS the equality —
TRUE when they agree, FALSE (a real filter) when they differ (the `AdjacencyMembership` non-vacuity
shape: the fix is a real tooth, not `True`). -/
theorem lastRowFix_commitment_zero_iff (a : Assignment) (hm : a IS_MERKLE = 0) :
    (invEqGate IS_MERKLE 5 54).eval a = 0 ↔ a 5 = a 54 := by
  have hz : (invEqGate IS_MERKLE 5 54).eval a = a 5 - a 54 := by
    simp only [invEqGate, subE, EmittedExpr.eval, hm]; ring
  rw [hz]; constructor <;> intro h <;> omega

-- Non-vacuity: the fixed-commitment binding ACCEPTS col5=col54, REJECTS col5≠col54 (spend row).
#guard decide ((invEqGate IS_MERKLE 5 54).eval (fun c => if c = IS_MERKLE then 0 else 7) = 0)
#guard decide (¬ ((invEqGate IS_MERKLE 5 54).eval
          (fun c => if c = 5 then 1 else 0) = 0))

/-! ## §9 — shape pins for the fixed descriptor. -/

#guard noteSpendLeafDescFixed.traceWidth == 149
#guard noteSpendLeafDescFixed.piCount == 7
#guard noteSpendLeafDescFixed.constraints.length == 33
#guard noteSpendLastRowFix.length == 6
-- the fix adds exactly six `VmRow.last` boundary constraints.
#guard (noteSpendLeafDescFixed.constraints.filter (fun c => match c with
          | .base (.boundary VmRow.last _) => true | _ => false)).length == 6

#assert_axioms lastRowFix_commitment_zero_iff

