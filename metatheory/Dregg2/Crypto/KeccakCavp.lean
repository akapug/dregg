    Keccak.shake128 (hexBytes "") 16 =
      hexBytes "7f9c2ba4e88f827d616045507605853e" := by native_decide
-- transcription guard: the pinned hex is even-length, all-hex, and exactly the CAVP byte count
#guard hexOfLen "" 0 && hexOfLen "7f9c2ba4e88f827d616045507605853e" 16

