/-! ## ML-DSA-65 verify parameters (FIPS 204 Table 2). -/

/-- Dropped low-order bits of `t`, FIPS 204: `d = 13` (the `t1` scaling is `2^d`). -/
def paramD : Nat := 13
/-- `γ₁ = 2¹⁹`. -/
def gamma1 : Nat := 524288
/-- `β = τ·η = 49·4 = 196`. -/
def betaBound : Nat := 196
/-- The `z` response bound `γ₁ − β = 524092`. -/
def zBound : Nat := 524092
/-- `γ₂ = (q−1)/32 = 261888`. -/
def gamma2 : Nat := 261888
/-- `α = 2γ₂ = 523776`. -/
def alpha : Nat := 523776
/-- `q` as an `Int`, for the centered decomposition. -/
def qI : Int := 8380417

/-! ## FIPS 204 `Decompose` / `HighBits` / `UseHint` (Algorithms 36 & 40) over the CENTERED residue.

`Decompose(r)` (Alg 36) centers the low part `r0 = r mod± α ∈ (−γ₂, γ₂]`, with the `r − r0 = q−1` special
case folding `r1` to `0`. `HighBits = r1 ∈ [0, 16)`. `UseHint` (Alg 40) carries `r1 ± 1 (mod m = 16)`. -/

/-- Centered modular reduction `mod± m` into `(−m/2, m/2]` (`m` even here, so `(−γ₂, γ₂]` for `m = α`). -/
def modpm (r : Int) (m : Int) : Int :=
  let r' := r % m           -- `Int.emod`: `r' ∈ [0, m)` for `m > 0`
  if r' > m / 2 then r' - m else r'

/-- FIPS 204 `Decompose` (Algorithm 36): `(r1, r0)` with `r0 = r mod± α` centered, and the `r − r0 = q−1`
special case (`r1 := 0`, `r0 := r0 − 1`). Input `r` is a canonical `ℤ_q` rep in `[0, q)`. -/
def decompose (r : Nat) : Int × Int :=
  let ri : Int := (r : Int) % qI
  let r0 := modpm ri (alpha : Int)
  if ri - r0 == qI - 1 then (0, r0 - 1)
  else ((ri - r0) / (alpha : Int), r0)

/-- FIPS 204 `HighBits` (Algorithm 38): the high part `r1` of `Decompose r`, in `[0, 16)`. -/
def highBits (r : Nat) : Int := (decompose r).1

/-- FIPS 204 `UseHint` (Algorithm 40) at `m = (q−1)/(2γ₂) = 16`: on `h = 1`, carry `r1 ± 1 (mod 16)` with the
sign taken from `r0`; else `r1`. `h` is a `{0,1}` hint coefficient. Result is in `[0, 16)`. -/
def useHint (h : Nat) (r : Nat) : Int :=
  let m : Int := 16
  let d := decompose r
  let r1 := d.1
  let r0 := d.2
  if h == 1 && r0 > 0 then (r1 + 1) % m
  else if h == 1 && r0 ≤ 0 then (r1 - 1) % m
  else r1

/-- Scale a `t1` polynomial by `2^d` in `R_q` (each coeff `· 2^13 mod q`), before its NTT. -/
def scaleT1 (p : Poly) : Poly := Id.run do
  let mut out := zeroPoly
  for i in [0:256] do
    out := out.set! i ((p[i]! * (2 ^ paramD)) % q)
  return out

/-- `w1Encode` (FIPS 204 Algorithm 28): `SimpleBitPack` of the `k = 6` `w1'` polynomials at 4 bits/coeff
(`w1'` coeffs are in `[0, 16)`), reusing the codec's `packBits`. Yields `6·128 = 768` bytes. -/
def w1Encode (w1 : Array Poly) : List UInt8 := Id.run do
  let mut out : Array UInt8 := #[]
  for i in [0:paramK] do
    out := out ++ packBits (w1[i]!) 4
  return out.toList

/-- The centered infinity norm `‖z‖∞`: the max over all `z` coefficients of `min(c, q−c)`. -/
def infNormZ (z : Array Poly) : Nat := Id.run do
  let mut mx := 0
  for p in z do
    for j in [0:256] do
      let c := p[j]!
      let a := if c ≤ q / 2 then c else q - c
      if a > mx then mx := a
  return mx

/-- **The REAL ML-DSA-65 verify** (FIPS 204 Algorithm 8 `verify_internal`, wrapped by Algorithm 3 for the
`ctx` framing). Returns `true` iff the recomputed challenge hash matches `c̃` AND `‖z‖∞ < γ₁ − β`. A rejected
hint (`sigDecode` sentinel `h.size ≠ k`) fails CLOSED. -/
def verifyCore (pk M ctx sig : List UInt8) : Bool := Id.run do
  let (rho, t1) := pkDecode pk
  let (ctilde, z, h) := sigDecode sig
  if h.size ≠ paramK then
    return false
  let aHat := expandA rho
  let tr := shake256 pk 64
  -- Algorithm 3 pure-framing of `M'`: `0x00 ‖ IntegerToBytes(|ctx|, 1) ‖ ctx ‖ M`.
  let mPrime := (UInt8.ofNat 0) :: (UInt8.ofNat ctx.length) :: (ctx ++ M)
  let mu := shake256 (tr ++ mPrime) 64
  let cHat := ntt (sampleInBall ctilde)
  -- Precompute `ntt(z_j)`.
  let mut zHat : Array Poly := Array.mkEmpty paramL
  for j in [0:paramL] do
    zHat := zHat.push (ntt (z[j]!))
  -- Per row: `w1'_i = UseHint(h_i, intt(Az_i − ct1_i))`.
  let mut w1 : Array Poly := Array.mkEmpty paramK
  for i in [0:paramK] do
    let mut az := zeroPoly
    for j in [0:paramL] do
      az := addPoly az (pointwiseMul (aHat[i * paramL + j]!) (zHat[j]!))
    let ct1 := pointwiseMul cHat (ntt (scaleT1 (t1[i]!)))
    let w := intt (subPoly az ct1)
    let hi := h[i]!
    let mut w1i := zeroPoly
    for jj in [0:256] do
      w1i := w1i.set! jj ((useHint (hi[jj]!) (w[jj]!)).toNat)
    w1 := w1.push w1i
  let cTildePrime := shake256 (mu ++ w1Encode w1) 48
  return (cTildePrime == ctilde) && (infNormZ z < zBound)

