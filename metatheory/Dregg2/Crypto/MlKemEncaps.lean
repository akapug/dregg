/-! ## THE GATE -- `native_decide`, BYTE-EXACT vs the NIST ACVP FIPS 203 expected values. -/

/-- **THE KEYSTONE**: `mlkemEncaps acvpEk acvpM = (acvpCt, acvpK)` -- the Lean encaps, on NIST's ACVP
encapsulation key and coins, reproduces NIST's expected ciphertext AND shared secret BYTE-FOR-BYTE. This
forces the full FO encaps pipeline -- `H = SHA3-256`, the `G = SHA3-512` split, and the entire K-PKE.Encrypt
(`ExpandA`, CBD from `PRF`, both `NTT` inverse products, both compressions, the transpose of `A-hat`) -- to
ALL match the NIST reference: a single wrong step yields `ct != acvpCt` or `K != acvpK`.

SCOPE (read the statement, not this prose): this is a SINGLE-VECTOR KAT, not a `forall`. It says the Lean
encaps agrees with NIST on ONE input pair. The for-all-inputs half lives in `EncapsCoreSpec`. -/
theorem encaps_matches_acvp :
    mlkemEncaps acvpEk.toList acvpM.toList = (acvpCt.toList, acvpK.toList) := by native_decide

/-- **ENCAPS -> DECAPS agree (through the K4 decaps), on NIST's own key pair**: the Lean decaps of the ACVP
`dk` over the Lean encaps's ciphertext recovers the Lean encaps's shared secret -- the two directions
round-trip end-to-end on the NIST `(ek, dk)` pair. Single-vector KAT, not a `forall`. -/
theorem encaps_decaps_roundtrip_acvp :
    mlkemDecaps acvpDk.toList (mlkemEncaps acvpEk.toList acvpM.toList).1 = acvpK.toList := by
  native_decide

/-- **THE KEYSTONE (byte-wire)**: the FFI, fed NIST's ACVP `ek` / `m` as the hex wire, emits
`hex(acvpCt) ++ " " ++ hex(acvpK)` -- the whole Rust -> Lean marshalling path reproduces the NIST expected
ciphertext + shared secret. Single-vector KAT, not a `forall`. -/
theorem mlkemEncapsRealFFI_matches_acvp :
    mlkemEncapsRealFFI (realWireEncaps acvpEk.toList acvpM.toList) =
      hexEncode acvpCt.toList ++ " " ++ hexEncode acvpK.toList := by
  native_decide

-- A malformed wire fails CLOSED (interpreted `#guard`, fast): wrong field count, odd-length hex, non-hex.
#guard mlkemEncapsRealFFI "zz zz" = "ERR"
#guard mlkemEncapsRealFFI "00" = "ERR"
#guard mlkemEncapsRealFFI "0 0" = "ERR"

end Dregg2.Crypto.MlKemEncaps
