namespace Dregg2.Crypto.MlDsaSignReal

open Dregg2.Crypto.MlDsaRing (Poly q zeroPoly ntt intt pointwiseMul addPoly subPoly)
open Dregg2.Crypto.Keccak (shake256)
open Dregg2.Crypto.MlDsaSampleInBall (sampleInBall)
open Dregg2.Crypto.MlDsaExpandA (expandA)
open Dregg2.Crypto.MlDsaCodec (unpackBits zCoeffFromField sigEncode hintEncode hintWeight
  paramK paramL omega)
open Dregg2.Crypto.MlDsaVerifyReal (decompose highBits w1Encode infNormZ gamma2 betaBound zBound)

/-! ## ML-DSA-65 sign-side parameters (FIPS 204 Table 2). -/

/-- `η = 4`, the `s1`/`s2` secret coefficient bound. -/
def etaP : Nat := 4
/-- Bits per packed `s1`/`s2` coefficient: `bitlen(2η) = bitlen(8) = 4`. -/
def etaBits : Nat := 4
/-- Bytes per packed `s1`/`s2` polynomial: `256·4/8 = 128`. -/
def etaStep : Nat := 128
/-- Bits per packed `t0` coefficient: `d = 13`. -/
def t0Bits : Nat := 13
/-- Bytes per packed `t0` polynomial: `256·13/8 = 416`. -/
def t0Step : Nat := 416
/-- `2^{d−1} = 2¹² = 4096`, the `t0` `BitUnpack` centre `b`. -/
def t0Half : Nat := 4096
/-- SHAKE-256 bytes per `ExpandMask` poly: `32·c = 32·20 = 640` (`c = 1 + bitlen(γ₁−1) = 20`). -/
def maskBytes : Nat := 640
/-- `γ₂ − β = 261888 − 196 = 261692`, the `r0` rejection bound. -/
def r0Bound : Nat := 261692

/-! ## `skDecode` (FIPS 204 Algorithm 24). -/

/-- Decode a `BitUnpack(·, b, b)`-style field to a canonical `ℤ_q` rep: the signed coefficient is `b − field`,
carried as `b − field` when nonnegative, else `q − (field − b)`. Covers `s1`/`s2` (`b = η`) and `t0`
(`b = 2^{d−1}`). -/
def bDecode (b field : Nat) : Nat := if field ≤ b then b - field else q - (field - b)

/-- **`skDecode` — FIPS 204 Algorithm 24 for ML-DSA-65.** Split the 4032-byte secret key into
`ρ (32) ‖ K (32) ‖ tr (64) ‖ s1 (ℓ·128) ‖ s2 (k·128) ‖ t0 (k·416)`, decoding each `s1`/`s2` poly at 4
bits/coeff (`BitUnpack(·, η, η)`) and each `t0` poly at 13 bits/coeff (`BitUnpack(·, 2^{d−1}−1, 2^{d−1})`),
carrying every coefficient as its canonical `ℤ_q` rep. -/
def skDecode (sk : List UInt8) :
    (List UInt8 × List UInt8 × List UInt8 × Array Poly × Array Poly × Array Poly) := Id.run do
  let b := sk.toArray
  let rho := (b.extract 0 32).toList
  let kk  := (b.extract 32 64).toList
  let tr  := (b.extract 64 128).toList
  -- s1 : ℓ = 5 polys, 128 bytes each, starting at offset 128.
  let s1Off := 128
  let mut s1 : Array Poly := Array.mkEmpty paramL
  for i in [0:paramL] do
    let fields := unpackBits b (s1Off + i * etaStep) 256 etaBits
    let mut p := zeroPoly
    for j in [0:256] do
      p := p.set! j (bDecode etaP (fields[j]!))
    s1 := s1.push p
  -- s2 : k = 6 polys, 128 bytes each.
  let s2Off := s1Off + paramL * etaStep
  let mut s2 : Array Poly := Array.mkEmpty paramK
  for i in [0:paramK] do
    let fields := unpackBits b (s2Off + i * etaStep) 256 etaBits
    let mut p := zeroPoly
    for j in [0:256] do
      p := p.set! j (bDecode etaP (fields[j]!))
    s2 := s2.push p
  -- t0 : k = 6 polys, 416 bytes each.
  let t0Off := s2Off + paramK * etaStep
  let mut t0 : Array Poly := Array.mkEmpty paramK
  for i in [0:paramK] do
    let fields := unpackBits b (t0Off + i * t0Step) 256 t0Bits
    let mut p := zeroPoly
    for j in [0:256] do
      p := p.set! j (bDecode t0Half (fields[j]!))
    t0 := t0.push p
  return (rho, kk, tr, s1, s2, t0)

/-! ## `ExpandMask` (FIPS 204 Algorithm 34). -/

/-- **`ExpandMask` — FIPS 204 Algorithm 34 for ML-DSA-65.** For `r = 0..ℓ−1`, drive SHAKE-256 over
`ρ' ‖ IntegerToBytes(κ+r, 2)` (2 little-endian bytes), read `32·20 = 640` bytes, and `BitUnpack(v, γ₁)` at 20
bits/coeff — the coefficient is `γ₁ − field`, the SAME sign map as the `z` codec (`zCoeffFromField`), so `y`
lands in `(−γ₁, γ₁]` carried as canonical `ℤ_q` reps. Returns `ℓ = 5` polynomials (normal domain). -/
def expandMask (rhoP : List UInt8) (kappa : Nat) : Array Poly := Id.run do
  let mut y : Array Poly := Array.mkEmpty paramL
  for r in [0:paramL] do
    let n := kappa + r
    let seed := rhoP ++ [UInt8.ofNat (n % 256), UInt8.ofNat (n / 256)]
    let v := (shake256 seed maskBytes).toArray
    let fields := unpackBits v 0 256 20
    let mut p := zeroPoly
    for j in [0:256] do
      p := p.set! j (zCoeffFromField (fields[j]!))
    y := y.push p
  return y

/-! ## `MakeHint` (FIPS 204 Algorithm 39) and the `r0`/norm helpers. -/

/-- **`MakeHint` per polynomial (FIPS 204 Algorithm 39).** Called as `h = MakeHint(−c·t0, w − c·s2 + c·t0)`:
for each coefficient set the hint bit to `1` iff `HighBits(w − c·s2 + c·t0) ≠ HighBits(w − c·s2)` (adding
`z = −c·t0` moves the high bits), i.e. `HighBits(r) ≠ HighBits(r + z)`. Inputs are the canonical `ℤ_q` polys
`wmcs2 = w − c·s2` and `ct0 = c·t0`. Result is a `{0,1}`-polynomial. -/
def makeHintPoly (wmcs2 ct0 : Poly) : Poly := Id.run do
  let mut h := zeroPoly
  for j in [0:256] do
    let r := (wmcs2[j]! + ct0[j]!) % q     -- w − c·s2 + c·t0
    let rz := wmcs2[j]!                     -- (w − c·s2 + c·t0) + (−c·t0) = w − c·s2
    let bit : Nat := if highBits r ≠ highBits rz then 1 else 0
    h := h.set! j bit
  return h

/-- `‖r0‖∞` where `r0 = LowBits(·)` is the centered low part (`= (Decompose ·).2 ∈ (−γ₂, γ₂]`) of each
coefficient of the canonical `ℤ_q` polys `wmcs2 = w − c·s2`. Returns `max |r0|`. -/
def r0InfNorm (wmcs2 : Array Poly) : Nat := Id.run do
  let mut mx := 0
  for p in wmcs2 do
    for j in [0:256] do
      let a := (decompose (p[j]!)).2.natAbs
      if a > mx then mx := a
  return mx

/-! ## The rejection loop and `signCore`. -/

/-- One attempt of the FIPS 204 Algorithm 7 rejection loop at counter `κ`, retrying with `κ += ℓ` on any
abort. `fuel` bounds the loop (a real key needs only a handful of iterations; the compiled `native_decide`
runs it directly). Returns the encoded signature, or `[]` if `fuel` is exhausted (never on real input). -/
partial def signAttempt (fuel kappa : Nat) (rhoP mu : List UInt8)
    (aHat s1Hat s2Hat t0Hat : Array Poly) : List UInt8 := Id.run do
  if fuel == 0 then
    return []
  -- 11: y ← ExpandMask(ρ', κ);  ŷ = NTT(y).
  let y := expandMask rhoP kappa
  let mut yHat : Array Poly := Array.mkEmpty paramL
  for l in [0:paramL] do
    yHat := yHat.push (ntt (y[l]!))
  -- 12: w = NTT⁻¹(Â ∘ ŷ), per row.
  let mut w : Array Poly := Array.mkEmpty paramK
  for i in [0:paramK] do
    let mut az := zeroPoly
    for l in [0:paramL] do
      az := addPoly az (pointwiseMul (aHat[i * paramL + l]!) (yHat[l]!))
    w := w.push (intt az)
  -- 13: w1 = HighBits(w).
  let mut w1 : Array Poly := Array.mkEmpty paramK
  for i in [0:paramK] do
    let wi := w[i]!
    let mut w1i := zeroPoly
    for j in [0:256] do
      w1i := w1i.set! j ((highBits (wi[j]!)).toNat)
    w1 := w1.push w1i
  -- 15: c̃ = H(μ ‖ w1Encode(w1), 48).
  let ctilde := shake256 (mu ++ w1Encode w1) 48
  -- 16-17: c = SampleInBall(c̃);  ĉ = NTT(c).
  let cHat := ntt (sampleInBall ctilde)
  -- 18-19: c·s1 (ℓ), c·s2 (k) via pointwise ∘ then NTT⁻¹.
  let mut cs1 : Array Poly := Array.mkEmpty paramL
  for l in [0:paramL] do
    cs1 := cs1.push (intt (pointwiseMul cHat (s1Hat[l]!)))
  let mut cs2 : Array Poly := Array.mkEmpty paramK
  for i in [0:paramK] do
    cs2 := cs2.push (intt (pointwiseMul cHat (s2Hat[i]!)))
  -- 20: z = y + c·s1.
  let mut z : Array Poly := Array.mkEmpty paramL
  for l in [0:paramL] do
    z := z.push (addPoly (y[l]!) (cs1[l]!))
  -- 21: r0 side needs w − c·s2.
  let mut wmcs2 : Array Poly := Array.mkEmpty paramK
  for i in [0:paramK] do
    wmcs2 := wmcs2.push (subPoly (w[i]!) (cs2[i]!))
  -- 23: reject on ‖z‖∞ ≥ γ₁ − β or ‖r0‖∞ ≥ γ₂ − β.
  if decide (zBound ≤ infNormZ z) || decide (r0Bound ≤ r0InfNorm wmcs2) then
    signAttempt (fuel - 1) (kappa + paramL) rhoP mu aHat s1Hat s2Hat t0Hat
  else
    -- 25: c·t0.
    let mut ct0 : Array Poly := Array.mkEmpty paramK
    for i in [0:paramK] do
      ct0 := ct0.push (intt (pointwiseMul cHat (t0Hat[i]!)))
    -- 26: h = MakeHint(−c·t0, w − c·s2 + c·t0).
    let mut h : Array Poly := Array.mkEmpty paramK
    for i in [0:paramK] do
      h := h.push (makeHintPoly (wmcs2[i]!) (ct0[i]!))
    -- 28: reject on ‖c·t0‖∞ ≥ γ₂ or #(h = 1) > ω.
    if decide (gamma2 ≤ infNormZ ct0) || decide (omega < hintWeight h) then
      signAttempt (fuel - 1) (kappa + paramL) rhoP mu aHat s1Hat s2Hat t0Hat
    else
      -- 32: return sigEncode(c̃, z, h).
      return sigEncode (ctilde, z, h)

/-- **The REAL ML-DSA-65 SIGN core** (FIPS 204 Algorithm 7 `Sign_internal`, deterministic `rnd = 0`, wrapped
by Algorithm 2 for the `ctx` framing). Decodes `sk`, expands `Â`/`ŝ1`/`ŝ2`/`t̂0`, computes `μ` and `ρ'`, then
runs the rejection loop. Returns the 3309-byte signature. -/
def signCore (sk msg ctx : List UInt8) : List UInt8 := Id.run do
  let (rho, kk, tr, s1, s2, t0) := skDecode sk
  let aHat := expandA rho
  let mut s1Hat : Array Poly := Array.mkEmpty paramL
  for l in [0:paramL] do
    s1Hat := s1Hat.push (ntt (s1[l]!))
  let mut s2Hat : Array Poly := Array.mkEmpty paramK
  for i in [0:paramK] do
    s2Hat := s2Hat.push (ntt (s2[i]!))
  let mut t0Hat : Array Poly := Array.mkEmpty paramK
  for i in [0:paramK] do
    t0Hat := t0Hat.push (ntt (t0[i]!))
  -- μ = H(tr ‖ 0x00 ‖ |ctx| ‖ ctx ‖ msg, 64).
  let mPrime := (UInt8.ofNat 0) :: (UInt8.ofNat ctx.length) :: (ctx ++ msg)
  let mu := shake256 (tr ++ mPrime) 64
  -- ρ' = H(K ‖ rnd ‖ μ, 64) with rnd = {0}³² (deterministic variant).
  let rnd : List UInt8 := List.replicate 32 (UInt8.ofNat 0)
  let rhoP := shake256 (kk ++ rnd ++ mu) 64
  return signAttempt 1000 0 rhoP mu aHat s1Hat s2Hat t0Hat

