+    /// Create an instance with no display handle, suitable for headless /
+    /// offscreen rendering (e.g. lavapipe software Vulkan). Unlike
+    /// [`Self::instance`], this does not require a window to source a display
+    /// handle from, so it can be constructed in a process with no windowing
+    /// system at all.
+    #[cfg(not(target_family = "wasm"))]
+    pub fn offscreen_instance() -> wgpu::Instance {
+        wgpu::Instance::new(wgpu::InstanceDescriptor {
+            backends: wgpu::Backends::VULKAN | wgpu::Backends::GL,
+            flags: wgpu::InstanceFlags::default(),
+            backend_options: wgpu::BackendOptions::default(),
+            memory_budget_thresholds: wgpu::MemoryBudgetThresholds::default(),
+            display: None,
+        })
+    }
+
+    /// Build a context for headless / offscreen rendering with **no surface**.
+    ///
+    /// Adapter selection cannot use surface-configuration as the compatibility
+    /// test (there is no surface), so this enumerates adapters, sorts them with
+    /// the same tier ordering used by the windowed path (discrete > integrated
+    /// > other > virtual > cpu, Vulkan/Metal/Dx12 preferred), and selects the
+    /// first adapter that yields a working device. Set `ZED_DEVICE_ID` to force
+    /// a specific adapter, or `ZED_OFFSCREEN_PREFER_CPU=1` to prefer a software
+    /// (CPU) rasterizer such as lavapipe/llvmpipe.
+    #[cfg(not(target_family = "wasm"))]
+    pub fn new_offscreen(instance: wgpu::Instance) -> anyhow::Result<Self> {
+        let device_id_filter = match std::env::var("ZED_DEVICE_ID") {
+            Ok(val) => parse_pci_id(&val)
+                .context("Failed to parse device ID from `ZED_DEVICE_ID` environment variable")
+                .log_err(),
+            Err(std::env::VarError::NotPresent) => None,
+            err => {
+                err.context("Failed to read value of `ZED_DEVICE_ID` environment variable")
+                    .log_err();
+                None
+            }
+        };
+        let prefer_cpu = std::env::var("ZED_OFFSCREEN_PREFER_CPU")
+            .map(|v| v != "0" && !v.is_empty())
+            .unwrap_or(false);
+
+        let (adapter, device, queue, dual_source_blending, color_texture_format) =
+            gpui::block_on(Self::select_offscreen_adapter_and_device(
+                &instance,
+                device_id_filter,
+                prefer_cpu,
+            ))?;
+
+        let device_lost = Arc::new(AtomicBool::new(false));
+        device.set_device_lost_callback({
+            let device_lost = Arc::clone(&device_lost);
+            move |reason, message| {
+                log::error!("wgpu device lost: reason={reason:?}, message={message}");
+                if reason != wgpu::DeviceLostReason::Destroyed {
+                    device_lost.store(true, Ordering::Relaxed);
+                }
+            }
+        });
+
+        log::info!(
+            "Selected offscreen GPU adapter: {:?} ({:?})",
+            adapter.get_info().name,
+            adapter.get_info().backend
+        );
+
+        Ok(Self {
+            instance,
+            adapter,
+            device: Arc::new(device),
+            queue: Arc::new(queue),
+            dual_source_blending,
+            color_texture_format,
+            device_lost,
+        })
+    }
+
+    #[cfg(not(target_family = "wasm"))]
+    async fn select_offscreen_adapter_and_device(
+        instance: &wgpu::Instance,
+        device_id_filter: Option<u32>,
+        prefer_cpu: bool,
+    ) -> anyhow::Result<(
+        wgpu::Adapter,
+        wgpu::Device,
+        wgpu::Queue,
+        bool,
+        TextureFormat,
+    )> {
+        let mut adapters: Vec<_> = instance.enumerate_adapters(wgpu::Backends::all()).await;
+
+        if adapters.is_empty() {
+            anyhow::bail!("No GPU adapters found");
+        }
+
+        adapters.sort_by_key(|adapter| {
+            let info = adapter.get_info();
+            let device_known = info.device != 0;
+
+            let user_override: u8 = match device_id_filter {
+                Some(id) if device_known && info.device == id => 0,
+                _ => 1,
+            };
+
+            // When prefer_cpu is set we invert the type ordering so software
+            // rasterizers (lavapipe/llvmpipe) sort first — useful for
+            // reproducible CI rendering and for VMs with no real GPU.
+            let is_cpu = info.device_type == wgpu::DeviceType::Cpu;
+            let type_priority: u8 = if prefer_cpu {
+                if is_cpu { 0 } else { 1 }
+            } else {
+                match info.device_type {
+                    wgpu::DeviceType::DiscreteGpu => 0,
+                    wgpu::DeviceType::IntegratedGpu => 1,
+                    wgpu::DeviceType::Other => 2,
+                    wgpu::DeviceType::VirtualGpu => 3,
+                    wgpu::DeviceType::Cpu => 4,
+                }
+            };
+
+            let backend_priority: u8 = match info.backend {
+                wgpu::Backend::Vulkan | wgpu::Backend::Metal | wgpu::Backend::Dx12 => 0,
+                _ => 1,
+            };
+
+            (user_override, type_priority, backend_priority)
+        });
+
+        log::info!("Found {} offscreen GPU adapter(s):", adapters.len());
+        for adapter in &adapters {
+            let info = adapter.get_info();
+            log::info!(
+                "  - {} (vendor={:#06x}, device={:#06x}, backend={:?}, type={:?})",
+                info.name,
+                info.vendor,
+                info.device,
+                info.backend,
+                info.device_type,
+            );
+        }
+
+        for adapter in adapters {
+            let info = adapter.get_info();
+            log::info!("Testing offscreen adapter: {} ({:?})...", info.name, info.backend);
+            match Self::create_device(&adapter).await {
+                Ok((device, queue, dual_source_blending, color_atlas_texture_format)) => {
+                    log::info!(
+                        "Selected offscreen GPU: {} ({:?})",
+                        info.name,
+                        info.backend
+                    );
+                    return Ok((
+                        adapter,
+                        device,
+                        queue,
+                        dual_source_blending,
+                        color_atlas_texture_format,
+                    ));
+                }
+                Err(e) => {
+                    log::info!(
+                        "  Offscreen adapter {} ({:?}) failed: {}, trying next...",
+                        info.name,
+                        info.backend,
+                        e
+                    );
+                }
+            }
+        }
+
+        anyhow::bail!("No GPU adapter found that can create an offscreen device")
+    }
