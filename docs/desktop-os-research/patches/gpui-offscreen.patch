+    /// Render `scene` into an owned offscreen texture (no window / surface
+    /// required) and read the pixels back as tightly-packed **RGBA8** bytes.
+    ///
+    /// This is the wgpu counterpart of macOS's
+    /// `MetalRenderer::render_scene_to_image`. It is the entry point for
+    /// headless rendering against e.g. lavapipe (software Vulkan) inside a VM,
+    /// or for compositing gpui content into another framebuffer.
+    ///
+    /// Returns `(rgba_bytes, width, height)` where `rgba_bytes.len() == width *
+    /// height * 4`, row-major, top row first, no padding. The internal target
+    /// texture is `Bgra8Unorm` (matching the windowed path and the atlas), and
+    /// the channels are swizzled BGRA→RGBA on readback so callers get RGBA
+    /// directly (suitable for `image::RgbaImage::from_raw`).
+    ///
+    /// Works on a surfaceless renderer built via [`new_offscreen`](Self::new_offscreen),
+    /// and also on a windowed renderer (it does not touch the surface).
+    pub fn render_scene_to_image(
+        &mut self,
+        scene: &Scene,
+        size: Size<DevicePixels>,
+    ) -> anyhow::Result<(Vec<u8>, u32, u32)> {
+        let width = size.width.0;
+        let height = size.height.0;
+        if width <= 0 || height <= 0 {
+            anyhow::bail!("Invalid size for render_scene_to_image: {:?}", size);
+        }
+        let width = width as u32;
+        let height = height as u32;
+        if width > self.max_texture_size || height > self.max_texture_size {
+            anyhow::bail!(
+                "render_scene_to_image size ({width}, {height}) exceeds max texture dimension {}",
+                self.max_texture_size
+            );
+        }
+
+        // Drive viewport-derived state (intermediate path textures, viewport
+        // globals) from the requested size, just like a resize would.
+        self.surface_config.width = width;
+        self.surface_config.height = height;
+        self.resources_mut().invalidate_intermediate_textures();
+
+        self.atlas.before_frame();
