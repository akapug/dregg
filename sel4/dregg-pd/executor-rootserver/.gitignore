# Standalone build dirs (own target dir, never the shared ./target).
/target
/target-roottask
# Provisioned build outputs (regenerated by scripts/provision-sel4.sh +
# scripts/relink-roottask.sh): the seL4 musl, the dummy libunwind, the
# seL4-musl-relinked executor archives, the assembled boot image.
/out
# The seL4 kernel + libsel4 headers (provisioned by scripts/provision-sel4.sh
# from the seL4 source tree + the kernel build; kernel.elf is a build output).
/sel4-prefix
Cargo.lock
