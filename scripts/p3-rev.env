# Single source of truth for the emberian/plonky3-recursion fork rev.
#
# P3_REV is the CI clone rev of the `update-plonky3-rev` fork tip that every
# plonky3-recursion consumer in this repo must pin in LOCKSTEP -- they are the
# SAME circuit or the verifier keys fork:
#   - Cargo.toml                             (root [workspace.dependencies]
#                                             p3-recursion/p3-circuit/... git rev
#                                             -- the AUTHORITATIVE pin)
#   - .github/workflows/extension.yml        (sibling clone REV)
#   - .github/workflows/publish-sdk-ts.yml   (sibling clone REV)
#   - .github/workflows/pages.yml            (sibling clone REV, several jobs)
#   - wasm/Cargo.toml                        (sibling-checkout comment)
#
# When you bump the fork: change P3_REV here, update every consumer above, then
# run `bash scripts/check-p3-rev.sh` to confirm they all agree.
#
# `scripts/check-p3-rev.sh` reads this value and FAILS if any lockstep consumer
# drifts. It additionally WARNs (does not fail) if RECURSION_P3_REV in
# circuit-prove/src/recursive_witness_bundle.rs -- the proving-system id folded
# into the deployed recursive VK hash -- drifts: fixing that re-keys the VK, a
# VK-epoch event on a separate human-gated track.
P3_REV=0a4a554e144f4e60107555ea7a11cd9969d6208b
