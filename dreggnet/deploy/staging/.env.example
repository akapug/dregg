# DreggNet staging config. Copy to `.env` next to docker-compose.yml on the box
# (deploy.sh ships this example; fill the node image ref + any overrides).

# Postgres credentials (staging — change for anything that matters).
POSTGRES_USER=dreggnet
POSTGRES_PASSWORD=dreggnet
POSTGRES_DB=dreggnet

RUST_LOG=info

# The pre-built linux/amd64 dregg-node image. dregg-node CANNOT be cross-built
# (host-native Lean archive), so it is built on a Lean-capable builder and either
# pushed to a registry or `docker save`d + loaded onto the box. Examples:
#   DREGG_NODE_IMAGE=ghcr.io/<you>/dregg-node:staging
#   DREGG_NODE_IMAGE=<AWS_ACCOUNT_ID>.dkr.ecr.us-east-1.amazonaws.com/dregg-node:staging
#   DREGG_NODE_IMAGE=dregg-node:staging        # if loaded locally via `docker load`
DREGG_NODE_IMAGE=dregg-node:staging

# Audit-grade node: prove every finalized turn (memory-hungry; needs t3.medium+).
DREGG_PROVE_TURNS=0

# ─── DreggNet Discord bot ────────────────────────────────────────────────────
# The pre-built linux/amd64 bot image (built natively, no cross-compile, with
# `--features dregg-sdk/no-lean-link`; `docker save`d + loaded onto the box).
DREGG_BOT_IMAGE=dregg-discord-bot:staging

# GO-LIVE SECRETS — set these to bring the bot up. The bot exits 1 without the
# first three, so until they are present it will not stay running.
#   DISCORD_TOKEN  : your bot token from the Discord developer portal (Bot tab).
#   DISCORD_APP_ID : the numeric Application ID (General Information tab).
#   BOT_SECRET     : 64 hex chars (32 bytes); the stable seed for per-user
#                    deterministic cipherclerk derivation. Generate ONCE and keep:
#                      openssl rand -hex 32
DISCORD_TOKEN=
DISCORD_APP_ID=
BOT_SECRET=

# The dregg node the bot drives. Defaults to the compose-internal edge node.
DEVNET_URL=http://dregg-node:8420

# blake3(node_pubkey) of the SOLO edge node — the executor signing domain.
# Transfers fail with an Ed25519 error if this is wrong/unset. The value below is
# blake3 of the current edge node's public_key
# (<EDGE_NODE_PUBKEY>); if the node
# key is ever rotated, the bot logs the new value at startup
# ("Set FEDERATION_ID=<hex> to match") — paste it here and restart.
FEDERATION_ID=<FEDERATION_ID>

# The /admin webportal: ADMIN_TOKEN gates it underneath Caddy basic-auth
# (defence in depth); generate one with `openssl rand -hex 24`. ADMIN_DISCORD_ID
# is ember's numeric Discord user id (right-click your name → Copy User ID with
# Developer Mode on). Both optional: unset ADMIN_TOKEN disables /admin (404).
ADMIN_TOKEN=
ADMIN_DISCORD_ID=

# --- OPS/ADMIN dashboard (dreggnet-ops) -------------------------------------
# The operator's single pane of glass at https://ops.dreggnet.example.com,
# behind a SEPARATE admin password (user `admin`) — a dedicated Caddy
# basic-auth block distinct from the public `operator` operator credential. The
# password itself is NOT an env var: it is bcrypt-hashed in the Caddyfile (the ops
# block). Rotate it with:
#   docker compose exec caddy caddy hash-password --plaintext '<new>'
# then paste the hash into the ops block in Caddyfile and `docker compose restart caddy`.
#
# The dashboard AGGREGATES the live read surfaces; these have working compose
# defaults and only need overriding off-stack:
#   OPS_NODE_URL    (default http://dregg-node:8420)
#   OPS_GATEWAY_URL (default http://gateway:8080)
#   OPS_BOT_URL     (default http://dreggnet-discord-bot:8080)
# OPS_ADMIN_TOKEN is an OPTIONAL app-layer Bearer/?token= gate UNDER the Caddy
# admin password (defence in depth); leave unset so the browser-behind-Caddy flow
# works. The bot's ADMIN_TOKEN (above) is reused to pull its /admin/api/hermes.
OPS_ADMIN_TOKEN=

# --- ops monitoring + alerting (see docs/MONITORING.md) ---------------------
# OPS_BACKEND_URL: the compute backend's /health (node-a / homelab :8021 over
#   the overlay). Defaults (in compose) to the node-a overlay; UNSET to silence
#   the backend-down WARN while node-a is offline.
# OPS_ALERT_WEBHOOK: OPTIONAL plain-HTTP sink the background alerter POSTs page/warn
#   alerts to ({"text":..,"content":..} — Slack/Discord-shaped). Plain HTTP only
#   (the ops binary has no TLS); for an https sink, poll GET /api/alerts from a
#   cron. Alerts always also go to the ops container log regardless.
# OPS_ALERT_INTERVAL_SECS: how often the alerter re-evaluates (default 30, min 5).
OPS_BACKEND_URL=
OPS_ALERT_WEBHOOK=
OPS_ALERT_INTERVAL_SECS=30

# --- cap-auth (dregg capability forward-auth) — the redeploy FLIP -----------
# webauth (the `forward_auth` service Caddy gates the operator/admin/gateway
# surfaces behind) replaces HTTP basic-auth with a dregg CAPABILITY. See
# docs/deos/SESSION-LOGIN.md. To TURN CAP-AUTH ON at the redeploy:
#   1. DREGGNET_CADDYFILE=./Caddyfile.capauth   (the hardened forward_auth config)
#   2. DREGG_WEBAUTH_ROOT_PUBKEY=<from `dregg-authctl keygen`>
#   3. CLEAR DREGG_WEBAUTH_BREAK_GLASS (leave it empty) so it is really cap-auth.
# Default (unset) keeps the current ./Caddyfile — a no-op, safe rollback.
DREGGNET_CADDYFILE=
# The issuer public key every presented session verifies under. REQUIRED for
# cap-auth: while unset every cap check DENIES (only break-glass admits).
DREGG_WEBAUTH_ROOT_PUBKEY=
# Break-glass override (X-Dregg-Break-Glass). KEEP SET only until the cap flow is
# exercised in production; CLEAR at cutover — a set break-glass admits without a
# credential, so it is not really cap-auth while it is on.
DREGG_WEBAUTH_BREAK_GLASS=
# Host→cap fallback map (the forward_auth ?cap= wins); session lifetime (24h);
# the shared challenge-MAC key (openssl rand -hex 32) + its TTL; the revocation
# deny-set file. All optional — sane defaults in docker-compose.yml.
DREGG_WEBAUTH_HOST_CAPS=
DREGG_WEBAUTH_SESSION_TTL=86400
DREGG_WEBAUTH_CHALLENGE_KEY=
DREGG_WEBAUTH_CHALLENGE_TTL=120
DREGG_WEBAUTH_REVOKED_FILE=
