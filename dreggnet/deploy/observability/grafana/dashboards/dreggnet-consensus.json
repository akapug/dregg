    {
      "id": 9,
      "type": "text",
      "title": "",
      "datasource": null,
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "options": {
        "mode": "markdown",
        "content": "**Live:** node up/down, consensus-live, finalizing, peers, block height (ops). **Enrichment follow-up:** the native `dregg_block_height` / divergence / tau counters are registered on the node but only emit once the node touches each family \u2014 today `dregg_federation_peers_connected` is the populated native series; the rich values come via the ops `/api/health` json-exporter.  \n**Enrichment (live):** `dregg_consensus_finality_latency_seconds` (first-vote\u2192quorum) and per-validator `dregg_validator_last_seen_timestamp_seconds` are now emitted by the node on every recorded finalization vote."
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Finality latency",
      "description": "Wall-clock from this node's first finalization vote for a block to consensus-wide quorum (Attested). Mean + p99 from the dregg_consensus_finality_latency_seconds summary.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "rate(dregg_consensus_finality_latency_seconds_sum[5m]) / rate(dregg_consensus_finality_latency_seconds_count[5m])",
          "refId": "A",
          "legendFormat": "mean"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "dregg_consensus_finality_latency_seconds{quantile=\"0.99\"}",
          "refId": "B",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Validator liveness (age of last vote)",
      "description": "Seconds since each committee member's last finalization vote was recorded (lower = healthier). A line that climbs without bound = a silent/absent validator.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "time() - dregg_validator_last_seen_timestamp_seconds",
          "refId": "A",
          "legendFormat": "{{voter}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Gossip rejection rate (federation health)",
      "description": "sum by (reason) rate(dregg_gossip_stream_rejected_total[5m]) \u2014 the edge gossip-storm early-warning. 0 in healthy operation; the panel that would have lit up red when the edge fell over.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "unit": "cps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.001
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "sum by (reason) (rate(dregg_gossip_stream_rejected_total[5m]))",
          "refId": "A",
          "legendFormat": "{{reason}}"
        }
      ]
    }
