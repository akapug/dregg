{
  "uid": "dreggnet-hosts",
  "title": "DreggNet · Host Overview",
  "tags": [
    "dreggnet",
    "hosts"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "dreggnet-prometheus"
        },
        "query": "label_values(node_uname_info, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Hosts up",
      "description": "node_exporter scrape liveness per host.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "up{job=\"node-exporter\",instance=~\"$host\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU usage %",
      "description": "100 - idle, averaged per instance over 5m.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$host\"}[5m])) * 100)",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Memory used %",
      "description": "1 - MemAvailable/MemTotal.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{instance=~\"$host\"} / node_memory_MemTotal_bytes{instance=~\"$host\"}))",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Memory used (bytes)",
      "description": "MemTotal - MemAvailable.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "node_memory_MemTotal_bytes{instance=~\"$host\"} - node_memory_MemAvailable_bytes{instance=~\"$host\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Disk used % per mount",
      "description": "Filesystem fill per mountpoint. Red at 85%.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "100 * (1 - (node_filesystem_avail_bytes{instance=~\"$host\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{instance=~\"$host\",fstype!~\"tmpfs|overlay|squashfs\"}))",
          "refId": "A",
          "legendFormat": "{{instance}} {{mountpoint}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Disk IO",
      "description": "Per-device read/write throughput over 5m.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "rate(node_disk_read_bytes_total{instance=~\"$host\"}[5m])",
          "refId": "A",
          "legendFormat": "{{instance}} {{device}} read"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "rate(node_disk_written_bytes_total{instance=~\"$host\"}[5m])",
          "refId": "B",
          "legendFormat": "{{instance}} {{device}} write"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Network throughput",
      "description": "Per-device rx/tx over 5m (loopback excluded).",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "rate(node_network_receive_bytes_total{instance=~\"$host\",device!=\"lo\"}[5m])",
          "refId": "A",
          "legendFormat": "{{instance}} {{device}} rx"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "rate(node_network_transmit_bytes_total{instance=~\"$host\",device!=\"lo\"}[5m])",
          "refId": "B",
          "legendFormat": "{{instance}} {{device}} tx"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Load average",
      "description": "1/5/15-minute load average per host.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "node_load1{instance=~\"$host\"}",
          "refId": "A",
          "legendFormat": "{{instance}} load1"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "node_load5{instance=~\"$host\"}",
          "refId": "B",
          "legendFormat": "{{instance}} load5"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "node_load15{instance=~\"$host\"}",
          "refId": "C",
          "legendFormat": "{{instance}} load15"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Uptime",
      "description": "node_time_seconds - node_boot_time_seconds per host.",
      "datasource": {
        "type": "prometheus",
        "uid": "dreggnet-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dreggnet-prometheus"
          },
          "expr": "node_time_seconds{instance=~\"$host\"} - node_boot_time_seconds{instance=~\"$host\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "text",
      "title": "",
      "datasource": null,
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "options": {
        "mode": "markdown",
        "content": "Host metrics from prometheus node_exporter on **edge** (container, `dreggnet_default`) + **node-a** & **node-b** (systemd, over the headscale overlay `:9100`). Disk-pressure alert at **>85%**. Runbook: `runbooks/INCIDENT-RESPONSE.md` / `docs/MONITORING.md`."
      }
    }
  ]
}
