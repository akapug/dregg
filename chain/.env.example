# Base Sepolia RPC (public endpoint or Alchemy/Infura)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployer wallet private key (with Base Sepolia ETH from faucet)
DEPLOYER_PRIVATE_KEY=

# SP1 Verifier Gateway on Base Sepolia
# Succinct Labs deploys this via deterministic CREATE2 on all EVM chains.
# See: https://docs.succinct.xyz/docs/verification/onchain/contract-addresses
# As of 2024: 0x3B6041173B80E77f038f3F2C0f9744f04837185e (SP1VerifierGateway)
SP1_VERIFIER_ADDRESS=0x3B6041173B80E77f038f3F2C0f9744f04837185e

# Verification key for the pyana SP1 guest program
# Generate with: cd chain/program && cargo prove vkey
PYANA_PROGRAM_VKEY=

# BaseScan API key (for contract verification)
ETHERSCAN_API_KEY=
