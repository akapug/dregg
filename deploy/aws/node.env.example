# Copy to /etc/dregg/node.env on the host and fill secrets there.
# Read by dregg-gateway.service (EnvironmentFile=-/etc/dregg/node.env).
# Do not commit the filled file.

# Cipherclerk passphrase. On first unlock this value sets the node passphrase;
# afterwards it must match. unlock-gateway.sh (the gateway ExecStartPost) uses
# it to POST /cipherclerk/unlock and, on success, writes DEVNET_API_TOKEN back
# into this file and /etc/dregg/discord-bot.env. Leave empty to skip automatic
# unlock (the node still starts, locked).
DEVNET_PASSWORD=

# Populated automatically by unlock-gateway.sh after a successful unlock.
# Leave empty here.
DEVNET_API_TOKEN=

# Idle heartbeat window in milliseconds (default 120000 = 2 min). Block
# production is mutation-driven: blocks are produced for submitted turns (and
# reactive acks of peer blocks); when fully idle the node emits ONE heartbeat
# block per window so liveness/finality probes still advance. Set 0 to disable
# idle heartbeats entirely. Overrides the --idle-heartbeat-ms flag when set.
#DREGG_IDLE_HEARTBEAT_MS=120000

# ── Domain / endpoint config (the "pathways") ───────────────────────────────
# The dregg production domains are centralized: code reads NAMED endpoints
# (see sdk/src/endpoints.rs + sdk-ts/src/endpoints.ts), each defaulting to the
# current value below, each overridable by one env var. Set these to point a
# deployment at production / a new domain WITHOUT editing the source. Unset =
# the current `*.fg-goose.online` defaults (behavior unchanged).
#DREGG_API_DOMAIN=dregg.fg-goose.online
#DREGG_DEVNET_DOMAIN=devnet.dregg.fg-goose.online
#DREGG_AUTH_DOMAIN=auth.dregg.fg-goose.online
#DREGG_GATEWAY_DOMAIN=gateway.dregg.fg-goose.online
#DREGG_HOSTING_DOMAIN=dregg.works
#DREGG_PORTAL_DOMAIN=portal.dregg.studio
# The Caddy front door serves DREGG_SITE_DOMAINS (see deploy/aws/caddy/Caddyfile)
# and deploy-site.sh prints DREGG_SITE_DOMAIN; keep the primary one in sync.
#DREGG_SITE_DOMAINS=devnet.dregg.fg-goose.online, dregg.fg-goose.online

# Reverse proxies whose X-Forwarded-For the node trusts (comma-separated IPs).
# The systemd unit defaults this to 127.0.0.1,::1 (the host-local Caddy).
# Without it, every external request keys the rate limiters on the proxy's
# loopback address — one shared bucket for the whole internet — and the
# pre-passphrase loopback gate would treat proxied strangers as local.
# Override here only if the proxy runs on another host.
#DREGG_TRUSTED_PROXIES=127.0.0.1,::1
