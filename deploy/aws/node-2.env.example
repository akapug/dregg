# Instance "node 2" of the 3-node federation (validator identity node-1 in
# genesis.json — see the mapping table in deploy/aws/N3-RUNBOOK.md).
#
# Copy to /etc/dregg/node-2.env on the host (root:dregg 0640) and fill any
# secrets THERE. Do not commit the filled file.
# Read by dregg-node@2.service (EnvironmentFile=/etc/dregg/node-2.env).

RUST_LOG=info

# HTTP API port (loopback-only; never proxied by Caddy, never in the security
# group). Gateway/node-0 owns 8420.
DREGG_PORT=8421

# QUIC gossip port. Gateway/node-0 owns 9420 (the only one open in the
# security group); 9421 stays internal.
DREGG_GOSSIP_PORT=9421

# Validator index in genesis.json (this instance signs with node-1.key,
# installed as /opt/dregg-data-2/node.key by federation-keygen.sh).
DREGG_NODE_INDEX=1

# The other two federation members on this host. MUST be IP:PORT literals —
# the peer parser (node/src/blocklace_sync.rs, SocketAddr::parse) silently
# skips hostnames.
DREGG_FEDERATION_PEERS=127.0.0.1:9420,127.0.0.1:9422

# ── Token convention (same as /etc/dregg/node.env) ──────────────────────────
# Cipherclerk passphrase. Internal nodes normally stay LOCKED (consensus
# signing does not need unlock; the faucet endpoint is token-free), so leave
# empty. Fill only if you want to unlock node 2 for operator turn-submit via
# `curl -X POST http://127.0.0.1:8421/cipherclerk/unlock` — there is no
# automatic ExecStartPost unlock on the template unit.
DEVNET_PASSWORD=

# Bearer token issued by a successful unlock. Leave empty here.
DEVNET_API_TOKEN=

# Idle heartbeat window in milliseconds (default 120000 = 2 min); see
# deploy/aws/node.env.example for the semantics.
#DREGG_IDLE_HEARTBEAT_MS=120000
