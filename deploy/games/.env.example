# deploy/games/.env.example — the dregg games stack env template.
#
# Copy to hbox at ~/.config/dregg/games.env and fill the real values, then
# `chmod 600 ~/.config/dregg/games.env`. NEVER commit the filled file.
# Both units (dregg-web-games.service + dregg-games-bot.service) read this one
# file; each ignores the vars it does not use.
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │ WEB GAMES SERVER (dregg-web-games.service — dreggnet-web-server)          │
# └──────────────────────────────────────────────────────────────────────────┘

# Bind address for the games web server — 127.0.0.1 ONLY (Caddy is the sole
# public surface). 8790 avoids the :8787 already used on hbox (OPS-RUNBOOK).
DREGGNET_WEB_BIND=127.0.0.1:8790

# Durable no-cheat Descent leaderboard (sqlite). Unset -> in-RAM (lost on restart).
# Re-verified by replay on boot. Lives in the units' ReadWritePaths.
DATABASE_URL=sqlite:/home/hbox/.local/state/dregg-games/leaderboard.db

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ DISCORD GAMES BOT (dregg-games-bot.service — dregg-discord-bot)           │
# └──────────────────────────────────────────────────────────────────────────┘

# REQUIRED — from the Discord developer portal. ⚠ ember places these; no prod
# token is ever committed or slung by an agent.
DISCORD_TOKEN=
DISCORD_APP_ID=
# 64 hex chars (32 bytes) — deterministic per-user cipherclerk derivation.
BOT_SECRET=

# The Descent daily-reveal announce channel (numeric Discord channel id). Unset ->
# the daily still rolls, it is only logged (no channel post). reveal_cron.rs.
DESCENT_ANNOUNCE_CHANNEL_ID=

# drand HTTP API base the daily-reveal cron fetches today's BLS-verified round
# from. Default (unset) = https://api.drand.sh (procgen_dregg::beacon::DRAND_API_BASE).
DRAND_API_BASE=https://api.drand.sh

# The bot's sqlite db (channels, gallery, characters). In the units' ReadWritePaths.
# NOTE: DATABASE_URL is shared with the web server above — if you want the bot and
# the web board in SEPARATE sqlite files, split games.env into two EnvironmentFiles
# (see deploy/games/RUNBOOK.md). One combined file is the low-friction default.

# ── OPTIONAL ────────────────────────────────────────────────────────────────
# Explicit node URL. The games demo is node-FREE, so leave UNSET for the standalone
# public demo. Set only if you also want the bot's devnet-backed commands live
# against a testnet node (Phase 2).
# DEVNET_URL=https://devnet.dregg.fg-goose.online

# The bot's HTTP read surface (Starbridge RemoteRuntime / observability). Localhost
# only; not part of the games public demo. Defaults 0.0.0.0:8080 in code — pin to
# localhost here so it is never exposed.
HTTP_HOST=127.0.0.1
HTTP_PORT=8092

# ── GATEWAY / DEPLOY (read by deploy-hbox.sh + the Caddy env) ────────────────
# The public games domain Caddy serves with Let's Encrypt TLS.
DREGG_GAMES_DOMAIN=demo.dregg.net
