# deploy/games/.env.funnel.example — the FUNNEL-variant games env template.
#
# Copy to hbox at ~/.config/dregg/games-funnel.env and fill the real values,
# then `chmod 600 ~/.config/dregg/games-funnel.env`. NEVER commit the filled file.
# The funnel web unit (dregg-web-games-funnel.service) reads this one file.
#
# This is the TAILSCALE-FUNNEL topology: the web server binds LOOPBACK and
# Tailscale Funnel proxies it publicly. There is NO AWS gateway and NO Caddy — so
# NONE of the gateway/Caddy vars from .env.example (DREGG_GAMES_DOMAIN /
# DREGG_GAMES_UPSTREAM) apply here.
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │ WEB GAMES SERVER (dregg-web-games-funnel.service — dreggnet-web-server)   │
# └──────────────────────────────────────────────────────────────────────────┘

# Bind address — LOOPBACK. Tailscale Funnel serves a LOCAL port: `tailscale
# funnel 8790` publishes 127.0.0.1:8790 at https://hbox-dregg.<tailnet>.ts.net.
# So the server binds loopback (contrast the gateway variant's tailnet-iface
# bind 100.95.240.73:8790). NEVER 0.0.0.0. 8790 is FREE on hbox.
DREGGNET_WEB_BIND=127.0.0.1:8790

# THE DEVNET SWITCH — anchor submitted Descent runs on the hbox solo devnet node
# (127.0.0.1:8420, the faucet node). resolve_node_target → NodeTarget::Federation:
# a submitted run's final committed turn-hash is settled onto that node's ledger
# and confirmed on GET /api/receipts. Unset → NodeTarget::Local (in-process only).
DREGG_NODE_URL=http://127.0.0.1:8420

# The node's API bearer token, if the node has a passphrase set. A loopback devnet
# node with NO passphrase needs none — leave unset. If you set a passphrase, fill
# this with the `bearer_token` returned by POST /cipherclerk/unlock (see
# RUNBOOK-FUNNEL step a). ⚠ ember places this; never committed.
# DREGG_NODE_BEARER=

# Durable no-cheat Descent leaderboard (sqlite). Unset -> in-RAM (lost on restart).
# Re-verified by replay on boot. Lives in the unit's ReadWritePaths.
DATABASE_URL=sqlite:/home/hbox/.local/state/dregg-games/leaderboard.db

# SHARED interaction-envelope audit dir (dreggnet-audit). Point this at the SAME
# absolute dir in ALL THREE services (this funnel web + dregg-telegram-bot + the
# discord unit) so a single `auditq correlate --dir <this>` joins a chain across
# them. The unit already sets this (Environment=DREGG_AUDIT_DIR=%h/.local/state/
# dregg/audit); keep it identical here if you set it. Per-process filenames
# (audit-DATE.<platform>-<pid>.NN.jsonl) make the one dir contention-free.
# `off` disables the audit log entirely.
DREGG_AUDIT_DIR=/home/hbox/.local/state/dregg/audit

# ── NOT USED in the funnel variant ───────────────────────────────────────────
# The Discord bot vars (DISCORD_TOKEN / DISCORD_APP_ID / BOT_SECRET / …) are NOT
# read here — the funnel fast-path is the WEB demo only (deploy-hbox.sh --funnel
# defaults SKIP_BOT=1). To also run the bot, use the gateway-variant games.env +
# dregg-games-bot.service; the bot is not part of the funnel public surface.
