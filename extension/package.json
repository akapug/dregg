{
  "name": "dregg-extension",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "node build-tests.mjs",
    "test": "node --test 'test/*.test.mjs'",
    "test:quiet-upgrade": "node --test tests/quiet-upgrade/run.mjs",
    "test:compose": "node --test tests/compose/run.mjs",
    "test:dregg-doc": "node --test tests/dregg-doc/run.mjs",
    "test:dregg-doc-editable": "node --test tests/dregg-doc-editable/run.mjs",
    "test:dregg-story": "node --test tests/dregg-story/run.mjs",
    "test:netlayer": "node --test tests/netlayer/run.mjs",
    "test:passkey": "node --test tests/passkey/run.mjs",
    "test:passkey-sign": "node --test tests/passkey-sign/run.mjs",
    "clean": "rm -rf dist test/.build"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "typescript": "^5.5.0",
    "@types/chrome": "^0.0.270"
  }
}
