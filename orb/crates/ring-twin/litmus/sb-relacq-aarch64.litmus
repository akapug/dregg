AArch64 SB-relacq-aarch64
(* Same store-buffering shape, release store (STLR) + acquire load (LDAR),
   the baseline (ARMv8.0, RCsc) lowering of C11 release/acquire.
   Bad final state 0:X2=0 /\ 1:X2=0 = lost wakeup. *)
{
0:X1=flag; 0:X3=data;
1:X1=data; 1:X3=flag;
}
 P0            | P1            ;
 MOV W0,#1     | MOV W0,#1     ;
 STLR W0,[X1]  | STLR W0,[X1]  ;
 LDAR W2,[X3]  | LDAR W2,[X3]  ;
exists (0:X2=0 /\ 1:X2=0)
