     aligned (shift (:64) + 1)
       (mc.target.get_reg ms mc.ptr2_reg +
        -1w * mc.target.get_reg ms mc.len_reg) ∧
     adj_ptr2 =
     mc.target.get_reg ms mc.len_reg + bytes_in_word * n2w max_stack_alloc ∧
     adj_ptr4 =
