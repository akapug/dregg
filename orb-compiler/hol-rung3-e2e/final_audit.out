     adj_ptr2 ≤₊ mc.target.get_reg ms mc.ptr2_reg ∧
     mc.target.get_reg ms mc.ptr2_reg ≤₊ adj_ptr4 ∧
     w2n
       (mc.target.get_reg ms mc.ptr2_reg +
        -1w * mc.target.get_reg ms mc.len_reg) ≤
     w2n bytes_in_word *
     (2 * max_heap_limit (:64) x64_backend_config.data_conf − 1) ∧
     w2n bytes_in_word *
