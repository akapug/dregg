byteInts length = 1268
bmInts    length = 1
bmInts values    = 4
--- corsBytes_length ---
⊢ LENGTH corsBytes = 1268
--- corsBitmaps_length ---
⊢ LENGTH corsBitmaps = 1
--- cors_compile_prog_native (LAYER 2, oracle) ---
⊢ ∃c'.
    compile_prog x64_config x64_backend_config corsProg =
    SOME (corsBytes,corsBitmaps,c')
LAYER2 oracles = [cake_native_bootstrap]  axioms = []
--- cors_pan_to_target_specialised (LAYER 1) ---
LAYER1 oracles = [DISK_THM]  axioms = []
LAYER1 antecedent conj1 = compile_prog_max c mc corsProg = (SOME (corsBytes,corsBitmaps,c'),stack_max)
LAYER2 head const   = pan_to_target$compile_prog
LAYER2 arg1 (asm)   = x64_target$x64_config
LAYER2 arg2 (cfg)   = x64_config$x64_backend_config
LAYER2 arg3 (prog)  = corsBytesBridge$corsProg
theory axioms (corsBytesBridge) = 0
