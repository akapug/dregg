byteInts length = 1088
bmInts    length = 1
bmInts values    = 4
--- gzipupperBytes_length ---
⊢ LENGTH gzipupperBytes = 1088
--- gzipupperBitmaps_length ---
⊢ LENGTH gzipupperBitmaps = 1
--- gzipupper_compile_prog_native (LAYER 2, oracle) ---
⊢ ∃c'.
    compile_prog x64_config x64_backend_config gzipupperProg =
    SOME (gzipupperBytes,gzipupperBitmaps,c')
LAYER2 oracles = [cake_native_bootstrap]  axioms = []
