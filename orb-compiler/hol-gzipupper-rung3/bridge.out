LAYER1 oracles = [DISK_THM]  axioms = []
LAYER1 antecedent conj1 = compile_prog_max c mc gzipupperProg =
(SOME (gzipupperBytes,gzipupperBitmaps,c'),stack_max)
LAYER2 head const   = pan_to_target$compile_prog
LAYER2 arg1 (asm)   = x64_target$x64_config
LAYER2 arg2 (cfg)   = x64_config$x64_backend_config
LAYER2 arg3 (prog)  = gzipupperBytesBridge$gzipupperProg
theory axioms (gzipupperBytesBridge) = 0
