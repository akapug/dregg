byteInts length = 1264
bmInts    length = 1
bmInts values    = 4
--- jwtBytes_length ---
⊢ LENGTH jwtBytes = 1264
--- jwtBitmaps_length ---
⊢ LENGTH jwtBitmaps = 1
--- jwt_compile_prog_native (LAYER 2, oracle) ---
⊢ ∃c'.
    compile_prog x64_config x64_backend_config jwtProg =
    SOME (jwtBytes,jwtBitmaps,c')
LAYER2 oracles = [cake_native_bootstrap]  axioms = []
--- jwt_pan_to_target_specialised (LAYER 1) ---
LAYER1 oracles = [DISK_THM]  axioms = []
LAYER1 antecedent conj1 = compile_prog_max c mc jwtProg = (SOME (jwtBytes,jwtBitmaps,c'),stack_max)
LAYER2 head const   = pan_to_target$compile_prog
LAYER2 arg1 (asm)   = x64_target$x64_config
LAYER2 arg2 (cfg)   = x64_config$x64_backend_config
LAYER2 arg3 (prog)  = jwtBytesBridge$jwtProg
theory axioms (jwtBytesBridge) = 0
