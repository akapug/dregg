val _ = load "traversalRung3Theory"; val _ = load "traversalBytesBridgeTheory";
open traversalRung3Theory traversalBytesBridgeTheory;
fun tag th = let val (o_,a)=Tag.dest_tag (Thm.tag th) in "[oracles: "^String.concatWith "," o_^"] [axioms: "^String.concatWith "," a^"]" end;
val _ = print ("AAA backbone traversal_rung3_native = "^tag traversal_rung3_native^"\n");
val _ = print ("AAA linkA traversal_decisioncore_refines_spec = "^tag traversal_decisioncore_refines_spec^"\n");
val _ = print ("AAA faithful traversalIf_faithful = "^tag traversalIf_faithful^"\n");
val _ = print ("AAA L2 traversal_compile_prog_native = "^tag traversal_compile_prog_native^"\n");
