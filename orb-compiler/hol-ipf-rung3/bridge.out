byteInts length = 1590
bmInts    length = 1
bmInts values    = 4
--- ipfBytes_length ---
⊢ LENGTH ipfBytes = 1590
--- ipfBitmaps_length ---
⊢ LENGTH ipfBitmaps = 1
--- ipf_compile_prog_native (LAYER 2, oracle) ---
⊢ ∃c'.
    compile_prog x64_config x64_backend_config ipfProg =
    SOME (ipfBytes,ipfBitmaps,c')
LAYER2 oracles = [cake_native_bootstrap]  axioms = []
--- ipf_pan_to_target_specialised (LAYER 1) ---
LAYER1 oracles = [DISK_THM]  axioms = []
LAYER1 antecedent conj1 = compile_prog_max c mc ipfProg = (SOME (ipfBytes,ipfBitmaps,c'),stack_max)
LAYER2 head const   = pan_to_target$compile_prog
LAYER2 arg1 (asm)   = x64_target$x64_config
LAYER2 arg2 (cfg)   = x64_config$x64_backend_config
LAYER2 arg3 (prog)  = ipfBytesBridge$ipfProg
theory axioms (ipfBytesBridge) = 0
